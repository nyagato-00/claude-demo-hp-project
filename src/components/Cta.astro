---
// 設計図 4-3 再利用パーツ「CTA ボタン（相談する／電話する）」。
// variant: "primary"（相談する・オレンジ） / "phone"（電話する・青緑アウトライン）
import { site, url } from "../data/site";

interface Props {
  variant?: "primary" | "phone";
  href?: string;
  label?: string;
}

const { variant = "primary", href, label } = Astro.props;
const isPhone = variant === "phone";
const rawHref = href ?? (isPhone ? `tel:${site.tel.replace(/-/g, "")}` : "/#contact");
// tel:・mailto:・外部URL は base を付けない。サイト内リンクのみ url() を通す。
const isExternal = /^(tel:|mailto:|https?:)/.test(rawHref);
const linkHref = isExternal ? rawHref : url(rawHref);
const text = label ?? (isPhone ? `電話する（${site.tel}）` : "相談する");
---

<a class:list={["cta", `cta--${variant}`]} href={linkHref}>
  {isPhone && <span class="cta__icon" aria-hidden="true">📞</span>}
  <span>{text}</span>
</a>

<style>
  .cta {
    display: inline-flex;
    align-items: center;
    gap: 0.5em;
    /* 指で押しやすいサイズ（設計図 第7節 レスポンシブ） */
    min-height: 52px;
    padding: 0.7em 1.6em;
    border-radius: 999px;
    font-weight: 700;
    font-size: 1.05rem;
    text-decoration: none;
    transition:
      background-color 0.15s ease,
      transform 0.05s ease;
  }

  .cta:active {
    transform: translateY(1px);
  }

  .cta--primary {
    background: var(--color-accent);
    color: #fff;
  }
  .cta--primary:hover {
    background: var(--color-accent-dark);
  }

  .cta--phone {
    background: #fff;
    color: var(--color-main-dark);
    border: 2px solid var(--color-main);
  }
  .cta--phone:hover {
    background: var(--color-soft);
  }
</style>
